{
  "name": "whathome",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "portless run next dev",
    "build": "next build",
    "vercel-build": "pnpm db:migrate && next build",
    "start": "next start",
    "check": "biome check",
    "lint": "biome check",
    "format": "biome check --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "auth:generate": "pnpm dlx auth@latest generate --output src/db/schema/auth.ts --yes",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ai-sdk/gateway": "3.0.77",
    "@base-ui/react": "1.3.0",
    "@hugeicons/core-free-icons": "4.0.0",
    "@hugeicons/react": "1.1.6",
    "@neondatabase/serverless": "1.0.2",
    "@vercel/blob": "2.3.2",
    "@vercel/config": "0.1.0",
    "@vercel/og": "0.11.1",
    "ai": "6.0.134",
    "better-auth": "1.6.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "drizzle-orm": "0.45.1",
    "next": "16.2.0",
    "nuqs": "2.8.9",
    "posthog-js": "1.363.1",
    "posthog-node": "5.28.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "workflow": "4.2.0-beta.73",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "portless": "0.9.1",
    "shadcn": "4.1.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
